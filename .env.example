# Copy this file to .env and fill in the values.
# .env is gitignored — never commit secrets.
# Both docker-compose.yml (prod) and dev/docker-compose.yml reference this file.

# --- Database ---
# POSTGRES_DB=myapp
# POSTGRES_USER=myapp
# POSTGRES_PASSWORD=changeme
# DATABASE_URL=postgres://myapp:changeme@db:5432/myapp

# --- Cache / Queue ---
# REDIS_URL=redis://redis:6379/0

# --- Application ---
# SECRET_KEY=changeme
# DEBUG=false
# ALLOWED_HOSTS=localhost,127.0.0.1

# --- External services ---
# Add API keys and third-party credentials here
